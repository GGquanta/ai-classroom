{
  "name": "ai-classroom",
  "version": "0.1.0",
  "private": true,
  "description": "团队 AI 协同办公与开发经验知识分享站点",
  "type": "module",
  "scripts": {
    "sync": "node --env-file-if-exists=.env --env-file-if-exists=.env.local scripts/sync-content.mjs",
    "test": "node --test tests/**/*.test.mjs",
    "docs:dev": "npm run sync && vitepress dev docs",
    "docs:build": "npm run sync && vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "deploy": "npm run docs:build && wrangler deploy"
  },
  "devDependencies": {
    "markdown-it": "^14.3.0",
    "vitepress": "^1.6.3",
    "wrangler": "^4.107.1"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@tabler/icons-vue": "^3.44.0",
    "fflate": "^0.8.2"
  }
}
